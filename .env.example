# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your_blob_token

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat

# Optional: dedicated fast deployment (legacy compatibility)
AZURE_OPENAI_ENDPOINT_FAST=
AZURE_OPENAI_API_KEY_FAST=
AZURE_OPENAI_API_VERSION_FAST=
AZURE_OPENAI_DEPLOYMENT_FAST=

# Optional: responses API version (for web-search capable calls)
AZURE_OPENAI_API_VERSION_RESPONSES=2025-04-01-preview

# NextAuth
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
